{# @pebvariable name="file_suffix" type="String" #}
{# @pebvariable name="name_suffix" type="String" #}
{# @pebvariable name="variant" type="String" #}
{% set light = ["", "bg", "mono"] contains variant %}
{% set bg = ["bg", "mono", "mono-dark"] contains variant %}
{# ----- #}
{% set background = light ? "EEEEEE" : "2E2E2E" %}
{% set border = light ? "A0A0A0" : "73808C" %}
{% set hoveredBackground = light ? "F3F3F3" : "565B5C"  %}
{% set primaryBackground = bg ? "FFF" : (light ? "F7F7F7" : "0E1415") %}
{% set searchMatchBackground = light ? "FFBC5D" : "00BFFF" %}
{% set selectionBackground = bg ? "B4D8FD" : light ? "BFDBFE" : "293334" %}
{% set selectionForeground = light ? "000" : "FFF" %}
{# ----- #}
{
  "author": "Alex Simkin",
  "dark": {{ not light }},
  "name": "Alabaster{{ name_suffix }}",
  "editorScheme": "/themes/alabaster{{ file_suffix }}.xml",
  "ui": {
    "Islands": 1,
    "Island": {
      "arc": 20,
      "arc.compact": 16,
      "borderArcLength": 14,
      "borderArcLength.compact": 10,
      "borderWidth": 6,
      "borderWidth.compact": 4,
      "borderColor": "#{{ border }}",
      "inactiveAlpha": 0.56,
      "toolWindowAlpha": 0.2
    },
    "*": {
      "background":  "#{{ background }}",
      "disabledBackground": "#{{ background }}",
      "hoveredBackground": "#{{ hoveredBackground }}",
      "inactiveBackground": "#{{ background }}",
      "selectionBackground": "#{{ selectionBackground }}",
      "selectionInactiveBackground": "#{{ selectionBackground }}",
      "selectionForeground": "#{{ selectionForeground }}",
      "selectionInactiveForeground": "#{{ selectionForeground }}"
    },
    "Editor": {
      "background": "#{{ primaryBackground }}"
    },
    "SearchMatch": {
      "endBackground": "#{{ searchMatchBackground }}",
      "startBackground": "#{{ searchMatchBackground }}"
    },
    "VersionControl": {
      "Log": {
        "Commit": {
          "currentBranchBackground": "#{{ primaryBackground }}"
        }
      }
    },
    "FileColor": {
      "Blue": "#{{ background }}",
      "Green": "#{{ background }}",
      "Orange": "#{{ background }}",
      "Rose": "#{{ background }}",
      "Violet": "#{{ background }}",
      "Yellow": "#{{ background }}"
    }
  }
}